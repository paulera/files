#!/bin/bash

result=$(curl \
    --user $JIRA_USER:$JIRA_API_TOKEN \
    -s \
    -o /dev/null \
    -w '%header{x-seraph-loginreason}' \
    $JIRA_URL)

if [ -z "$result" ] || [ "$result" == "OK" ]; then
    printf "${cGreen}OK${c0}\n"
elif [ "$result" == "AUTHENTICATED_FAILED" ] || [ "$result" == "AUTHENTICATED_FAILED" ]; then
    printf "${cRed}${result}${c0}\n"
fi
